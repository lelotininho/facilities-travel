# Copie este arquivo para .env.local e preencha com suas chaves
# NUNCA suba o arquivo .env.local para o GitHub

# Chave da API Anthropic (obrigatória para a busca com IA)
# Use este valor para desenvolvimento local e no Vercel como SECRET:
# VITE_ANTHROPIC_API_KEY é exposto ao cliente no build, então
# em produção prefira definir ANTHROPIC_API_KEY como secret no Vercel.
VITE_ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# Supabase (opcional — para salvar dados de usuários)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_AQUI
